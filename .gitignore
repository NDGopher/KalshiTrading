# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc
*.tsbuildinfo
.expo
.expo-shared

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Environment / Secrets
.env
.env.*
*.env
*.env.*

# pmxt / parquet cache (large binaries — do not commit)
/data/kalshi/**
!/data/kalshi/.gitkeep

# JBecker / extracted Kalshi parquet (~tens of GB, many files — sync outside git).
# Ignore directory contents but keep an empty tree marker (see root README).
/data/jbecker-data/*
!/data/jbecker-data/.gitkeep

# Full JBecker archive download (multi‑GB — never commit)
/data/jbecker-data.tar.zst
/data/*.tar.zst

# Backtest JSON/CSV outputs are tracked (multi-rank reports for dashboard / reproducibility)

# Local database files
*.db
*.db-journal
*.sqlite
*.sqlite3
*.sqlite-journal

# Replit
.cache/
.local/
